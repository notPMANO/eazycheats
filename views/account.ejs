<% pageTitle = 'Account settings' %>
<%- include('partials/header') %>

<section class="page-head">
  <div class="page-head-inner">
    <div class="page-head-icon"><span><%= (user.display_name || user.username || user.email).charAt(0).toUpperCase() %></span></div>
    <div>
      <nav class="crumbs"><a href="/">Home</a> <span>/</span> Account</nav>
      <h1>Account settings</h1>
      <p class="muted">
        Signed in as <strong><%= user.email %></strong>
        <% if (user.email_verified) { %>
          <span class="badge badge-good">Verified</span>
        <% } else { %>
          <span class="badge badge-warn">Unverified</span>
        <% } %>
      </p>
    </div>
  </div>
</section>

<section class="container narrow account-page">

  <% if (emailChangeLink) { %>
    <div class="dev-note">
      <p><strong>Dev mode:</strong> email sending isn't set up yet, so use this link to confirm your new email address:</p>
      <a href="<%= emailChangeLink %>" class="btn btn-primary btn-block">Verify new email</a>
    </div>
  <% } %>

  <!-- Profile -->
  <div class="card-form">
    <h2 class="admin-h2">Profile</h2>
    <form action="/account/profile" method="POST" class="form">
      <label>Username <small class="hint">3–20 letters, numbers or _</small>
        <input type="text" name="username" value="<%= user.username || '' %>" required minlength="3" maxlength="20" pattern="[a-zA-Z0-9_]{3,20}">
      </label>
      <label>Display name <small class="hint">Shown around the site.</small>
        <input type="text" name="display_name" value="<%= user.display_name || '' %>" maxlength="40">
      </label>
      <div class="form-actions"><button type="submit" class="btn btn-primary">Save profile</button></div>
    </form>
  </div>

  <!-- Email -->
  <div class="card-form">
    <h2 class="admin-h2">Email address</h2>
    <% if (user.pending_email) { %>
      <p class="muted">Pending change to <strong><%= user.pending_email %></strong> — awaiting verification.</p>
    <% } %>
    <form action="/account/email" method="POST" class="form">
      <label>New email address
        <input type="email" name="email" placeholder="you@example.com" required autocomplete="email">
      </label>
      <label>Current password <small class="hint">Confirm it's you.</small>
        <input type="password" name="password" required autocomplete="current-password">
      </label>
      <div class="form-actions"><button type="submit" class="btn btn-primary">Change email</button></div>
      <small class="hint">You'll get a verification link to confirm the new address before it takes effect.</small>
    </form>
  </div>

  <!-- Password -->
  <div class="card-form">
    <h2 class="admin-h2">Password</h2>
    <form action="/account/password" method="POST" class="form">
      <label>Current password
        <input type="password" name="current" required autocomplete="current-password">
      </label>
      <label>New password <small class="hint">At least 8 characters.</small>
        <input type="password" name="password" required minlength="8" autocomplete="new-password">
      </label>
      <label>Confirm new password
        <input type="password" name="confirm" required minlength="8" autocomplete="new-password">
      </label>
      <div class="form-actions"><button type="submit" class="btn btn-primary">Change password</button></div>
    </form>
  </div>

</section>

<%- include('partials/footer') %>
