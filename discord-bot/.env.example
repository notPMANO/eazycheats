# === EazyCheats Discord Bot config ===
# Copy this file to ".env" and fill in the values.

# The bot token from the Discord Developer Portal (Bot tab -> Reset Token -> Copy).
# TREAT THIS LIKE A PASSWORD. Never share it or commit it.
DISCORD_TOKEN=

# Your server's ID. Enable Developer Mode in Discord (Settings -> Advanced),
# then right-click your server icon -> "Copy Server ID".
GUILD_ID=

# The bot's Application ID (Developer Portal -> General Information -> Application ID).
# Only needed to auto-generate the invite link.
CLIENT_ID=
