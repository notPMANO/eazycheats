# Copy to .env and fill in. In production, set these on your host's dashboard.
NODE_ENV=production
PORT=3000
SESSION_SECRET=            # long random string (e.g. `openssl rand -hex 32`)
ADMIN_EMAIL=phoenix@edis.org
APP_URL=https://eazycheats.com
REQUIRE_EMAIL_VERIFICATION=true

# Resend (smtp)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=                 # your Resend API key (re_...)
MAIL_FROM=EazyCheats <no-reply@eazycheats.com>

# Persistent disk mount path (e.g. /var/data on Render)
DATA_DIR=/var/data
